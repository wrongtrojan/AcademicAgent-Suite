# Canonical template — copy to repo root:  cp .env.example .env

DATABASE_URL=postgresql://contextmap:contextmap@postgres:5432/contextmap
REDIS_URL=redis://redis:6379/0
STORAGE_ROOT=/data/storage
PUBLIC_BASE_URL=http://localhost:8000
# Docker workers: map localhost gateway URLs to the gateway service (see shared/http_utils.py)
GATEWAY_INTERNAL_ORIGIN=http://gateway:8000

# Logging (all Python services): DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# 可选：落盘日志目录（Compose 默认挂载到仓库 ./logs；本地可设为绝对路径）
# LOG_DIR=/var/log/contextmap
# 单文件上限与备份个数（字节 / 份数，可选）
# LOG_FILE_MAX_BYTES=20971520
# LOG_FILE_BACKUP_COUNT=5
# Gateway only: comma-separated path prefixes to omit from HTTP access INFO lines
# CONTEXTMAP_LOG_HTTP_SKIP_PREFIXES=/api/v1/health

# Embeddings: hash (default) or bge (requires sentence-transformers + torch)
EMBEDDING_BACKEND=hash
EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DEVICE=cuda

# MinerU: auto | api | module | cli | skip | synthetic
MINERU_MODE=auto

# URL policy: set to 0 in production if only HTTPS/S3 URLs are allowed
ALLOW_FILE_URL=1

# MinIO (optional object storage for presigned URLs)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=contextmap

OPENAI_API_BASE=
OPENAI_API_KEY=

# Video: VIDEO_WHISPER=1 + faster-whisper (GPU image) or openai-whisper / whisper CLI
VIDEO_WHISPER=0
WHISPER_BACKEND=auto
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_MODEL=base

# Visual: VISUAL_BACKEND=api (OpenAI-compatible) or local (Qwen2-VL)
VISUAL_USE_VLM=0
VISUAL_BACKEND=
QWEN_VL_MODEL_ID=
QWEN_VL_TORCH_DTYPE=bfloat16
VISUAL_MAX_PIXELS=802816
VISUAL_MAX_NEW_TOKENS=256

# Optional: service_manager concurrency (see docs/MODELS_AND_GPU.md)
# CONTEXTMAP_LIMIT_PDF_RECOGNITION=1
# NVIDIA_VISIBLE_DEVICES=all

# Sandbox: python snippet mode (off by default)
SANDBOX_ALLOW_PYTHON=0
SANDBOX_PYTHON_TIMEOUT=5

SERVICE_MANAGER_CONSUMER=sm-1

# Optional: Redis consumer group name per worker (defaults are in each services/*/worker/main.py).
# Only set when running multiple replicas of the same worker type.
# WORKER_CONSUMER=pdf-1
